<style>
:root{--quick-add-icon-size-mobile:1.65rem}.quick-add-mobile-container{bottom:var(--space-2);position:absolute;right:var(--space-1);z-index:2;width:var(--quick-add-icon-size-mobile);height:var(--quick-add-icon-size-mobile)}.quick-add-desktop-container{width:100%;height:auto;position:absolute;bottom:var(--space-2);padding-left:var(--space-2);padding-right:var(--space-2);z-index:2;opacity:0;display:none;transition:all .2s var(--default-easing)}@media screen and (min-width:940px){.quick-add-desktop-container{display:flex;flex-direction:row;grid-gap:var(--space-2)}.quick-add-desktop-container modal-opener,.quick-add-desktop-container product-form{width:100%}}@media (hover:hover){.product-card-grid:focus-within .quick-add-desktop-container,.product-card-grid:hover .quick-add-desktop-container{opacity:1;transform:translateY(0)}}.quick-add__submit{border:none;border-radius:var(--border-radius-tiny);box-sizing:border-box;cursor:pointer;left:0;min-width:0;opacity:1;right:0;text-transform:uppercase;top:auto;transition:all .3s var(--default-easing);z-index:2;width:var(--quick-add-icon-size-mobile);height:var(--quick-add-icon-size-mobile);display:flex;align-items:center;font-size:var(--text-size-tiny);justify-content:center}.quick-add-mobile-container .quick-add__submit{padding:0}.product-card-grid:focus-within .quick-add__submit,.product-card-grid:hover .quick-add__submit{opacity:1;transform:translateY(0)}@media screen and (min-width:940px){.quick-add__submit{opacity:1;transform:translateY(0);height:auto;width:100%;border-radius:var(--border-radius-large);margin-bottom:0;border:2px solid rgb(var(--color-button-primary-border))}}.quick-add__submit-icon{display:flex;align-items:center;justify-content:center}.quick-add__submit.loading .quick-add__submit-icon{opacity:0}.quick-add__submit .loading__spinner{width:1.25rem;height:1.25rem}.sold-out-message.hidden{display:none}.quick-add-modal{position:fixed;top:0;left:0;width:100%;height:100%;display:flex;align-items:flex-start;justify-content:center;background-color:rgba(0,0,0,.3);backdrop-filter:blur(4px);opacity:0;visibility:hidden;z-index:-1;transition:opacity .3s .1s,visibility .3s,z-index .3s;overflow-y:auto;padding-top:clamp(12vw,12rem,15vw)}.quick-add-modal[open]{opacity:1;visibility:visible;z-index:101}.quick-add-modal__content{background-color:rgb(var(--color-brand-1));border-radius:var(--border-radius-large);color:rgb(var(--color-brand-2));height:auto;max-width:65rem;width:calc(100% - var(--space-4));overflow:hidden;transform:scale(.95);transition:transform .3s}.quick-add-modal[open] .quick-add-modal__content{transform:scale(1)}@media screen and (min-width:750px){.quick-add-modal__content{width:85%}}@media screen and (min-width:990px){.quick-add-modal__content{width:80%}}.quick-add-modal__content-info{display:flex;height:100%;padding:var(--space-4)}.quick-add-modal__toggle{position:absolute;top:var(--space-3);right:var(--space-3);width:3rem;height:3rem;display:flex;align-items:center;justify-content:center;background-color:transparent;border:none;border-radius:50%;cursor:pointer;transition:background-color .2s;z-index:5;color:rgb(var(--color-brand-2))}.quick-add-modal__toggle:hover svg{transform:rotate(90deg)}.quick-add-modal__toggle svg{fill:currentColor;transition:transform .3s var(--default-easing)}quick-add-modal .product{display:flex;flex-direction:column;gap:var(--space-5);margin:0;min-height:0;max-width:100%}quick-add-modal .product.reverse-desktop-up>div:first-child{grid-column:1!important}quick-add-modal .product.reverse-desktop-up>div:last-child{grid-column:2!important}quick-add-modal .product__contain{padding:0}quick-add-modal .product__media-wrapper{width:100%;max-width:100%;order:1}@media screen and (min-width:750px){.quick-add-modal__content-info{padding:var(--space-6);padding-left:var(--space-4)}.quick-add-modal__toggle{top:var(--space-4);right:var(--space-4)}quick-add-modal .product{display:grid;grid-template-columns:1.15fr 1fr;gap:var(--space-7);align-items:start}quick-add-modal .product__media-wrapper{order:0}}quick-add-modal .product__info-wrapper{width:100%;max-width:100%;padding:0;order:2;display:flex;flex-direction:column;justify-content:flex-start;height:100%}quick-add-modal .product__info-container{height:100%;padding-bottom:0}@media screen and (min-width:750px){quick-add-modal .product__info-wrapper{order:0;justify-content:center}quick-add-modal media-gallery{grid-template-columns:0.25fr 2fr!important;grid-template-rows:1fr}quick-add-modal media-gallery .product-media-gallery__main{grid-column:2!important;grid-row:1;margin-bottom:0}quick-add-modal media-gallery .product-media-gallery__thumbnails{grid-column:1!important;grid-row:1}}quick-add-modal .product__title-wrapper{max-width:22em}quick-add-modal .product-form{margin-bottom:0;margin-top:auto}quick-add-modal .breadcrumbs,quick-add-modal .bsub-widget,quick-add-modal .installment,quick-add-modal .klaviyo-bis-trigger,quick-add-modal .product-sticky-button,quick-add-modal .product__accordion,quick-add-modal .shopify-payment-button{display:none}quick-add-modal .page-width{padding:0}quick-add-modal .product-form__buttons,quick-add-modal .product__info-container{margin:0;max-width:100%}quick-add-modal .price__badge-sale,quick-add-modal .price__badge-sold-out{background-color:rgba(var(--color-text-1),.1);color:rgb(var(--color-text-1))}quick-add-modal .tabbed-interface .tabbed-interface__panel,quick-add-modal .tabbed-interface .tabbed-interface__tabs{display:none}quick-add-modal .tabbed-interface__quick-add-view-more-link{display:block}@media screen and (max-width:749px){.quick-add-modal__content{border-radius:var(--border-radius-main);max-height:calc(100vh - var(--space-4));width:calc(100% - var(--space-2))}.quick-add-modal__content-info{padding:var(--space-3)}quick-add-modal .product__info-container>*{margin-bottom:var(--space-3)}quick-add-modal .product-form__buttons{border-top:1px solid rgba(var(--color-text-1),.1);margin-top:var(--space-5);padding-top:var(--space-4)}}
</style>
