/*------------------------------------*\
  #Font Declarations
\*------------------------------------*/

@font-face {
  font-family: 'Mabry-Regular';
  src: url('{{- 'mabry-regular-pro.woff2' | asset_url -}}') format('woff2'),
       url('{{ 'mabry-regular-pro.woff' | asset_url }}') format('woff');
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}

@font-face {
  font-family: 'Mabry-Medium';
  src: url('{{- 'mabry-medium-pro.woff2' | asset_url -}}') format('woff2'),
       url('{{ 'mabry-medium-pro.woff' | asset_url }}') format('woff');
  font-weight: 500;
  font-style: normal;
  font-display: swap;
}